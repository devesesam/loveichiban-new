---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  title: string;
  description: string;
  linkHref: string;
  linkText: string;
  linkExternal?: boolean;
}

const { image, imageAlt, title, description, linkHref, linkText, linkExternal = false } = Astro.props;
---

<div class="service-card fade-in">
  <Image src={image} alt={imageAlt} width={400} height={250} loading="lazy" />
  <h3>{title}</h3>
  <p>{description}</p>
  <a
    href={linkHref}
    class="btn btn-outline-dark"
    target={linkExternal ? '_blank' : undefined}
    rel={linkExternal ? 'noopener noreferrer' : undefined}
  >
    {linkText}
  </a>
</div>
